# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/.open-next/
/.wrangler/

# production
/build
**/build/
**/.gradle/
**/DerivedData/
**/Pods/
**/local.properties

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# native app provider config files
**/google-services.json
**/GoogleService-Info.plist

# local server logs
dev-server*.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
